    },
    {
      "id": "residence_years",
      "label": "छत्तीसगढ़ में निवास के वर्ष",
      "labelEn": "Years of Residence in CG",
      "type": "number",
      "required": true,
      "min": 0,
      "max": 100,
      "tooltip": "छत्तीसगढ़ में कितने वर्षों से निवास कर रहे हैं?"
    },
    {
      "id": "address",
      "label": "वर्तमान पता",
      "labelEn": "Current Address",
      "type": "text",
      "required": true,
      "minLength": 10,
      "tooltip": "वर्तमान पूरा पता दर्ज करें।"
    },
    {
      "id": "permanent_address",
      "label": "स्थायी पता",
