      "type": "text",
      "required": true,
      "minLength": 10,
      "tooltip": "स्थायी पता दर्ज करें।"
    },
    {
      "id": "pincode",
      "label": "पिन कोड",
      "labelEn": "Pin Code",
      "type": "text",
      "required": true,
      "pattern": "^\\d{6}$",
      "tooltip": "6 अंकों का पिन कोड।"
    },
    {
      "id": "mobile",
      "label": "मोबाइल नंबर",
      "labelEn": "Mobile Number",
      "type": "text",
      "required": true,
      "pattern": "^[6-9]\\d{9}$",
      "tooltip": "10 अंकों का मोबाइल नंबर।"
    }
  ]
